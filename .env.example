# Required
ANTHROPIC_API_KEY=sk-ant-...

# MCP Transport (stdio for local dev, http for Docker)
MCP_TRANSPORT=stdio
RESEARCH_KB_PATH=/path/to/research-kb
# RESEARCH_KB_URL=http://research-kb:8000  # Docker mode

# Model overrides (optional)
# PLANNING_MODEL=claude-haiku-4-5-20251001
# SYNTHESIS_MODEL=claude-sonnet-4-6
# ANALYSIS_MODEL=claude-sonnet-4-6

# Limit tuning (optional)
# MAX_SEARCH_RESULTS=10
# MAX_CONCEPTS=15
# MAX_CITATIONS=20

# LangSmith observability (optional - no-op without these)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=research-agent
