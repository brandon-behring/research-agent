# Required
ANTHROPIC_API_KEY=sk-ant-...

# MCP Transport
# MCP_TRANSPORT=stdio
# RESEARCH_KB_PATH=~/Claude/research-kb
# RESEARCH_KB_URL=http://research-kb:8000
# RESEARCH_KB_PYTHON=
# MCP_PATH=/mcp

# Model selection
# PLANNING_MODEL=claude-haiku-4-5-20251001
# SYNTHESIS_MODEL=claude-sonnet-4-6

# Pipeline limits
# MAX_SEARCH_RESULTS=10
# MAX_CONCEPTS=15
# MAX_CITATIONS=20
# SYNTHESIS_TIMEOUT=120

# Report cache
# CACHE_ENABLED=true
# CACHE_DB_PATH=~/.cache/research-agent/cache.db
# CACHE_TTL_HOURS=24
